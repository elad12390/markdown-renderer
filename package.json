{
  "name": "markdown-renderer-cli",
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "description": "Render extended markdown into real HTML and SVG with GFM, KaTeX, Mermaid, Graphviz, sanitization, and browser-backed static export.",
  "author": "Elad Benhaim",
  "license": "MIT",
  "homepage": "https://github.com/elad12390/markdown-renderer#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elad12390/markdown-renderer.git"
  },
  "bugs": "https://github.com/elad12390/markdown-renderer/issues",
  "keywords": [
    "markdown",
    "renderer",
    "mermaid",
    "katex",
    "graphviz",
    "cli",
    "html",
    "svg"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./cli": "./dist/cli.mjs",
    "./static-export": "./dist/static-export.mjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": "./markdown-renderer-cli",
  "files": [
    "dist",
    "markdown-renderer-cli"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm test:e2e && pnpm build && publint",
    "prepublishOnly": "pnpm check",
    "release": "bumpp",
    "start": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@viz-js/viz": "catalog:rendering",
    "katex": "catalog:rendering",
    "mermaid": "catalog:rendering",
    "rehype-parse": "catalog:rendering",
    "rehype-raw": "catalog:rendering",
    "rehype-sanitize": "catalog:rendering",
    "rehype-stringify": "catalog:rendering",
    "remark-gfm": "catalog:rendering",
    "remark-math": "catalog:rendering",
    "remark-parse": "catalog:rendering",
    "remark-rehype": "catalog:rendering",
    "unified": "catalog:rendering",
    "unist-util-visit": "catalog:rendering"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:cli",
    "@antfu/ni": "catalog:cli",
    "@playwright/test": "catalog:testing",
    "@types/node": "catalog:types",
    "bumpp": "catalog:cli",
    "eslint": "catalog:cli",
    "lint-staged": "catalog:cli",
    "playwright": "catalog:testing",
    "publint": "catalog:cli",
    "simple-git-hooks": "catalog:cli",
    "tsdown": "catalog:cli",
    "tsx": "catalog:cli",
    "typescript": "catalog:cli",
    "vite": "catalog:cli",
    "vitest": "catalog:testing"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm i --frozen-lockfile --ignore-scripts --offline && npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
